# TopDev Backend — Environment Variables Template
# Copy this to .env and fill in your real values
# cp .env.example .env

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

DATABASE_URL=postgresql+asyncpg://topdev:topdev@postgres:5432/topdev
SYNC_DATABASE_URL=postgresql://topdev:topdev@postgres:5432/topdev
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret
